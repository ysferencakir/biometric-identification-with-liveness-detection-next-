# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Biometric ID API"
APP_VERSION="0.1.0"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/biometric.db

# ── InsightFace ───────────────────────────────────────────────────────────────
# Model name; 'buffalo_l' = most accurate, 'buffalo_s' = faster/lighter
INSIGHTFACE_MODEL=buffalo_l

# 0 = first GPU (CUDA), -1 = CPU
INSIGHTFACE_CTX_ID=0

# ── Recognition ───────────────────────────────────────────────────────────────
# Cosine similarity threshold (0.0–1.0); raise to reduce false positives
RECOGNITION_THRESHOLD=0.45

# Minimum face dimension in pixels; faces smaller than this are ignored
MIN_FACE_SIZE=60

# ── Registration ──────────────────────────────────────────────────────────────
# Minimum frames with a valid face required during registration
REGISTER_FRAMES_REQUIRED=5

# ── Embedding storage ─────────────────────────────────────────────────────────
EMBEDDINGS_DIR=data/embeddings
